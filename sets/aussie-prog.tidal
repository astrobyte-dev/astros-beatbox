-- Aussie prog-psy jam — built live with Claude, 2026-05-24
-- (140 BPM rolling psy + Liquid-Soul-style broken-vocal build/drop)

-- ============ THE GROOVE (the drop) ============
setcps (140/60/4)
d1 $ sound "bd*4" # gain 1.0
d2 $ n "[~ 0 0 0]*4" # s "jvbass" # gain 0.92 # legato 0.45 # cutoff 750 # resonance 0.15
d3 $ sound "[~ ho]*4" # gain 0.6
d4 $ sound "[hh*3]*4" # gain 0.4 # pan rand # room 0.1 # orbit 1
d5 $ degradeBy 0.15 $ sound "[~ east east]*4" # n (irand 7) # gain 0.5 # pan (range 0.15 0.85 rand) # speed (range 0.97 1.05 rand) # room 0.25 # size 0.75 # orbit 1
d6 $ every 2 (const $ sound "~ ~ ~ cp*3" # gain 0.7 # speed 1.3) silence
d10 $ slow 8 $ note "c4'min7 af3'maj7 bf3'maj7 g3'min7" # sound "supersaw" # gain 0.3 # cutoff (range 1500 4500 (slow 8 sine)) # room 0.5 # size 0.8 # legato 1.1 # orbit 1

-- ============ THE BUILD (breakdown + broken vocal) ============
-- Eval these (silences groove), let it climb ~16 bars, then re-eval the groove block to drop.
d1 silence
d2 silence
d3 silence
d4 silence
d5 silence
d6 silence
d11 $ stut 3 0.5 (1/16) $ chop 4 $ sound "yeah*2" # n (irand 31) # speed (range 0.82 1.0 (slow 16 saw)) # gain (range 0.45 0.82 (slow 16 saw)) # cutoff (range 1200 6000 (slow 16 saw)) # room 0.45 # size 0.85 # orbit 1
d12 $ sound "sn*<2 4 4 8 8 16 16 32>" # gain (range 0.4 0.78 (slow 8 saw)) # room 0.3 # size 0.6 # orbit 1
d13 $ sound "hh*16" # cutoff (range 600 12000 (slow 16 saw)) # gain (range 0.12 0.5 (slow 16 saw)) # pan rand # room 0.5 # size 0.8 # orbit 1

-- hush  -- stop everything
